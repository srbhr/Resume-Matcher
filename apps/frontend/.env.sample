# Resume Matcher Frontend Configuration
# Copy this file to .env.local and update values as needed

# ===========================================
# API Configuration
# ===========================================
# Backend API URL - defaults to "/" (same-origin, proxied by Next.js rewrites).
# Only change this if running the backend on a separate host/port during development.
# NEXT_PUBLIC_API_URL=/

# Request timeout in milliseconds for long-running calls (resume tailoring),
# applied to both the Next.js API proxy and the client fetch. Default 240000
# (240s). Raise it for slow local LLMs; bounded to [30000, 1800000].
# IMPORTANT: keep it in sync with the BACKEND's REQUEST_TIMEOUT_SECONDS
# (= this / 1000) — the shortest of the two aborts first.
# NEXT_PUBLIC_REQUEST_TIMEOUT_MS=240000

# ===========================================
# Development Server (optional)
# ===========================================
# To change the frontend port, use: npm run dev -- -p 3001
# Or add to package.json scripts: "dev": "next dev --turbopack -p 3001"
#
# If you change the frontend port, make sure to update:
# 1. Backend CORS_ORIGINS to include your new frontend URL
# 2. Backend FRONTEND_BASE_URL to point to your new frontend URL